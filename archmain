#!/usr/bin/env bash
set -euo pipefail

# =========== CONFIGURATION =================

# SUDO CHECK

if [ "$EUID" -ne 0 ]; then
  echo "Run this script with sudo"
  exit 1
fi

if [ -n "$SUDO_USER" ]; then
  echo "Running via sudo (user: $SUDO_USER)"
else
  echo "Running as root directly"
fi

# DEFINE PATHS

USER_HOME="$(eval echo ~$SUDO_USER)"
: "${ARCHMAIN_REC:=$USER_HOME}"
: "${ARCHMAIN_DEST:=/mnt/backup}"
: "${ARCHMAIN_LOGFILE:=$USER_HOME/archmain-log.txt}"
: "${ARCHMAIN_HEALTHFILE:=$USER_HOME/archmain-health.txt}"

REC="$ARCHMAIN_REC"
DEST="$ARCHMAIN_DEST"
LOGFILE="$ARCHMAIN_LOGFILE"
HEALTHFILE="$ARCHMAIN_HEALTHFILE"

declare -A LOADED_MODULES=()
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# =========== ERROR & SAFETY HANDLING =======

# LOGGING FUNCTION

log() {

    if [[ ! -f "$LOGFILE" ]]; then
        mkdir -p "$(dirname "$LOGFILE")"
        touch "$LOGFILE"
    fi

    echo "LOG: $(date '+%F %T') - $1" | tee -a "$LOGFILE"

}

log "Archmain started"

# SILENT FAIL

ignore_fail() {

    if ! "$@"; then
        log "Ignored failure: $*"
    fi

}

# WARNED FAIL

warn_fail() {

    if ! "$@"; then
        echo "Warning: $* failed"
        log "WARNING: $* failed"
    fi

}

# ERROR TRAP

catch() {

    local line=$1
    local cmd=$2
    local exit_code=$?

    echo "Error on line $line: $cmd (exit $exit_code)"
    log "ERROR: line $line: $cmd (exit $exit_code)"

}

trap catch ERR

## CONFIRM FUNCTION

confirm() {
    local prompt="${1:-Are you sure?}"
    read -r -p "$prompt [y/N]: " ans
    case "$ans" in
        [yY]|[yY][eE][sS]) return 0 ;;
        *) return 1 ;;
    esac
}

# QUIT FUNCTION

quit() {

    log "Quit"
    echo "Goodbye!"
    exit 0

}

# CHECK TOOLS

echo "Checking correct tools..."
log "Checking correct tools"

check_dep() {
    if ! command -v "$1" >/dev/null; then
        echo "Error: required dependency '$1' is not installed." >&2
        log "Missing dependency: $1"
        exit 1
    fi
}

check_dep pacman
check_dep rsync
check_dep fwupdmgr
check_dep pacdiff

echo "All tools installed!"

